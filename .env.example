# Copy to .env and fill in. Keys stay local (MVP). All optional:
# without keys the pipeline still runs — silent narration, no Claude scripting.

# Claude — narration + zoom/highlight suggestions
ANTHROPIC_API_KEY=

# ElevenLabs — voice (bring your own key)
ELEVENLABS_API_KEY=

# Azure Speech (alternative TTS)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
